{
  "name": "@xoxno/sdk-js",
  "version": "1.0.88",
  "description": "The SDK to interact with the XOXNO Protocol!",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "files": [
    "dist/**/*"
  ],
  "sideEffects": false,
  "scripts": {
    "test": "jest",
    "build:sdk": "npx bun run src/sdk/parseSwagger.ts && npx oxlint src/sdk/swagger.ts --fix && npx bun run md/extract.ts",
    "build:types": "tsc --emitDeclarationOnly",
    "build:esm": "webpack --config webpack-esm.config.mjs",
    "build:cjs": "webpack --config webpack-cjs.config.mjs",
    "build": "npm run build:sdk && npm run build:types && npm run build:esm && npm run build:cjs",
    "lint": "oxlint src",
    "format": "oxlint src --fix",
    "commit": "git-cz",
    "release": "semantic-release",
    "docs": "typedoc --out docs src/**/*.ts"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XOXNO/sdk-js.git"
  },
  "husky": {
    "hooks": {
      "commit-msg": "npx --no-install commitlint --edit \"$1\"",
      "pre-commit": "npm run format && npm run lint && npm run docs",
      "pre-push": "npm test"
    }
  },
  "keywords": [
    "XOXNO",
    "MultiversX",
    "NFTs",
    "Blockchain",
    "Crypto"
  ],
  "author": "Mihai Eremia",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/XOXNO/sdk-js/issues"
  },
  "homepage": "https://github.com/XOXNO/sdk-js#readme",
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@multiversx/sdk-extension-provider": "^5.1.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.11",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "bun": "^1.3.9",
    "commitizen": "^4.2.4",
    "cookies-next": "^6.1.1",
    "cz-conventional-changelog": "^3.3.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "oxlint": "^1.47.0",
    "semantic-release": "^25.0.3",
    "swc-loader": "^0.2.7",
    "terser-webpack-plugin": "^5.3.16",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1",
    "webpack-merge": "^6.0.1",
    "yaml": "^2.8.2"
  },
  "dependencies": {
    "@multiversx/sdk-core": "^15.3.2",
    "@multiversx/sdk-network-providers": "^2.9.3",
    "@xoxno/types": "^1.0.377"
  }
}
